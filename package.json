{
  "name": "@infero.mcp/better-fetch",
  "version": "1.0.0",
  "description": "Advanced MCP server for web scraping with nested URL fetching and intelligent markdown formatting",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "prepublishOnly": "npm run clean && npm run build",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "cheerio": "^1.0.0-rc.12",
    "node-fetch": "^3.3.2",
    "turndown": "^7.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "bin": {
    "better-fetch": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "web-scraper",
    "documentation",
    "markdown",
    "crawler",
    "web-crawler",
    "content-extraction"
  ],
  "author": "flutterninja9",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flutterninja9/better-fetch.git"
  },
  "homepage": "https://github.com/flutterninja9/better-fetch#readme",
  "bugs": {
    "url": "https://github.com/flutterninja9/better-fetch/issues"
  }
}
